# Konfigurasi Database (Prisma)
# Gunakan Session pooling URL (Port 6543) untuk DATABASE_URL
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Gunakan Direct connection URL (Port 5432) untuk DIRECT_URL
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Kredensial Supabase Frontend (Autentikasi & Storage)
# Dapatkan dari: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# CRON Secret untuk melindungi endpoint cron cleanup
# Gunakan string random yang panjang (contoh: openssl rand -hex 32)
CRON_SECRET="your-cron-secret-here"
